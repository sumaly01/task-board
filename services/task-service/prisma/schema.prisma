// Prisma schema for task-service
//
// This service manages projects and tasks. It has its own PostgreSQL database
// completely separate from auth-service. The task-service never queries the
// auth DB — user identity arrives via the JWT payload decoded at the gateway.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  tasks     Task[]
  createdAt DateTime @default(now())
}

model Task {
  id           String    @id @default(uuid())
  title        String
  description  String?
  status       Status    @default(TODO)
  priority     Priority  @default(MEDIUM)
  dueDate      DateTime?
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  assigneeId   String
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // AI enrichment fields — written by ai-service via task.enriched Kafka event.
  // Null until enrichment arrives (~2-5s after task creation).
  // aiEnriched flips to true when the first enrichment is written; the frontend
  // uses this as the signal to show the AI suggestions badge and panel.
  aiDescription String?
  aiPriority    Priority?
  aiEffort      String?   // XS | S | M | L | XL — not a DB enum to avoid a migration per change
  aiTags        String[]
  aiEnriched    Boolean   @default(false)
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}
